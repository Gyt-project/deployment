# ──────────────────────────────────────────────────────────────────────────────
#  GYT — Environment variables
#
#  Copy this file to .env and fill in every value before running docker compose.
#  The .env file is loaded automatically by Docker Compose.
#
#  NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────


# ── Public URL ────────────────────────────────────────────────────────────────
# The full HTTPS base URL of your deployment (no trailing slash).
# Used by HAProxy CORS headers, the live service, and baked into the
# Next.js client bundle for the live PR WebSocket URL.
PUBLIC_URL=https://gyt.example.com


# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=gyt
DB_PASSWORD=change-me-strong-password
DB_NAME=gytdb


# ── Redis ─────────────────────────────────────────────────────────────────────
# Set a strong password — Redis is not exposed externally but requirepass is
# still enforced for defence in depth.
REDIS_PASSWORD=change-me-redis-password


# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
JWT_SECRET=change-me-super-secret-jwt-key-at-least-32-chars


# ── HAProxy ───────────────────────────────────────────────────────────────────
# Password for the /stats page (reachable only inside the Docker network on :8404).
HAPROXY_STATS_PASSWORD=change-me-stats-password


# ── soft-serve ────────────────────────────────────────────────────────────────
# Space-separated list of SSH public keys that will be granted admin access
# on first boot.  Leave empty to configure access via the soft-serve CLI later.
# Example: SOFT_SERVE_INITIAL_ADMIN_KEYS="ssh-ed25519 AAAA... user@host"
SOFT_SERVE_INITIAL_ADMIN_KEYS=
